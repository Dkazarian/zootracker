{
  "name": "zootracker",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently --kill-others --names frontend,backend --prefix-colors cyan,green \"npm run dev --workspace frontend\" \"npm run start:dev --workspace backend\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspace frontend && npm run test --workspace backend && npm run test:e2e --workspace backend",
    "test:auth:e2e": "npm run test:auth:e2e --workspace backend",
    "test:personnel:e2e": "npm run test:personnel:e2e --workspace backend",
    "test:animals:e2e": "npm run test:animals:e2e --workspace backend",
    "test:feeding-plans:e2e": "npm run test:feeding-plans:e2e --workspace backend",
    "test:feeding-tasks:e2e": "npm run test:feeding-tasks:e2e --workspace backend",
    "build": "npm run build --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:migrate": "npm run prisma:migrate --workspace backend",
    "prisma:migrate:deploy": "npm run prisma:migrate:deploy --workspace backend",
    "prisma:seed": "npm run prisma:seed --workspace backend",
    "auth:bootstrap-admin": "npm run auth:bootstrap-admin --workspace backend"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "prettier": "^3.9.1"
  },
  "dependencies": {
    "@nestjs/swagger": "^11.4.5",
    "swagger-ui-express": "^5.0.1"
  }
}
