{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "extensionsToTreatAsEsm": [".ts"],
  "setupFiles": ["<rootDir>/set-env.ts"],
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.tsx?$": [
      "ts-jest",
      {
        "useESM": true,
        "tsconfig": "<rootDir>/../tsconfig.spec.json"
      }
    ]
  }
}
