# Replace the username and password with credentials from your local PostgreSQL installation.
DATABASE_URL="postgresql://postgres:your-password@localhost:5432/zootracker?schema=public"

# Generate a private value of at least 32 characters. Never commit the real secret.
BETTER_AUTH_SECRET="replace-with-a-random-secret-at-least-32-characters"
BETTER_AUTH_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:5173"

# Used only by npm run auth:bootstrap-admin.
ADMIN_NAME="Zoo Administrator"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-a-strong-initial-password"
