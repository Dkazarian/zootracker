# Zootracker Codex context exclusions
#
# Keep core logic visible:
# - specs/, backlog/, and project documentation
# - frontend/src/features/, frontend/src/shared/, and frontend/src/app/
# - backend/src/ feature modules
# - backend/prisma/schema.prisma, migrations/, and seed.ts
# - tests, package manifests, configuration, and CI workflows
#
# Ignored files can still be inspected explicitly when a task requires them.

# Dependency trees and package-manager caches
**/node_modules/
**/.npm/
**/.pnpm-store/
**/.yarn/
**/.pnp.*

# Dependency resolution files (large and rarely useful during feature work)
package-lock.json
**/package-lock.json
pnpm-lock.yaml
yarn.lock

# Compiled, bundled, and framework-generated outputs
**/dist/
**/build/
**/out/
**/.next/
**/.nuxt/
**/.vite/
**/.turbo/
**/.parcel-cache/
**/.cache/
**/*.tsbuildinfo

# Test and analysis outputs
**/coverage/
**/.nyc_output/
**/test-results/
**/playwright-report/
**/junit.xml
**/lcov.info

# Generated source code
backend/src/generated/
**/generated/

# Binary assets and media (filenames/imports remain visible in source code)
frontend/src/assets/
**/public/assets/
**/static/assets/
**/*.png
**/*.jpg
**/*.jpeg
**/*.gif
**/*.webp
**/*.avif
**/*.ico
**/*.bmp
**/*.tif
**/*.tiff
**/*.woff
**/*.woff2
**/*.ttf
**/*.otf
**/*.mp3
**/*.wav
**/*.ogg
**/*.mp4
**/*.webm
**/*.mov

# Local databases, exports, archives, and dumps
**/*.sqlite
**/*.sqlite3
**/*.db
**/*.dump
**/*.sql.gz
**/*.zip
**/*.tar
**/*.tar.gz
**/*.7z

# Runtime logs, temporary files, and process state
**/*.log
**/*.pid
**/*.seed
**/*.tmp
**/*.temp
**/*.bak
**/*.swp
**/*.swo
**/tmp/
**/temp/

# Secrets and local environment overrides; retain documented examples
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example
!**/.env.test.example
!**/.env*.example

# Repository-local scratch and generated artifact directories
outputs/
work/

# Version-control internals and local agent/editor state
.git/
.agents/
.codex/
.continue/
.idea/
.vscode/

# Operating-system metadata
.DS_Store
**/.DS_Store
Thumbs.db
**/Thumbs.db
Desktop.ini
**/Desktop.ini
